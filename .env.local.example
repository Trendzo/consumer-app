# Copy to `.env.local` and restart Expo with a cache clear:  npx expo start -c
# All EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.

# ── Backend ──────────────────────────────────────────────────────────────────
# Base URL INCLUDING the /api/v1 prefix. Defaults to the live Render deploy.
EXPO_PUBLIC_API_BASE=https://backend-qpmx.onrender.com/api/v1

# ── MSG91 OTP widget (consumer login) ────────────────────────────────────────
# Public widgetId / tokenAuth for the CONSUMER OTP widget. The defaults baked
# into src/config/env.ts are the *retailer* widget (the only creds in this repo)
# — the backend verifies consumer tokens against a SEPARATE consumer MSG91
# account, so real consumer login needs the consumer widget's pair here.
EXPO_PUBLIC_MSG91_WIDGET_ID=3667636f3464353730373939
EXPO_PUBLIC_MSG91_TOKEN_AUTH=547225TSvi20QFa026a47d90aP1

# Default country dial code for phone entry (India = 91).
EXPO_PUBLIC_DIAL_CODE=91

# ── Virtual try-on (existing, unrelated to auth) ─────────────────────────────
# EXPO_PUBLIC_HF_TOKEN=hf_xxx
